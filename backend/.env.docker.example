DATABASE_URL=postgresql+psycopg://postgres.your-project-ref:your-password@aws-0-your-region.pooler.supabase.com:6543/postgres?sslmode=require
# If you prefer the bundled docker-compose db service instead:
# DATABASE_URL=postgresql+psycopg://syra:change-me-strong-password@db:5432/syra_lms
# Optional: set this to your direct Supabase Postgres URL if DATABASE_URL uses
# the Supabase session pooler and you want Alembic migrations to run through a
# separate direct connection.
# DATABASE_MIGRATION_URL=postgresql+psycopg://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
JWT_SECRET=change-me-to-a-random-32-character-string
JWT_ALGORITHM=HS256
BREVO_API_KEY=
BREVO_BASE_URL=https://api.brevo.com/v3
BREVO_SENDER_EMAIL=lms@zedny.ai
BREVO_SENDER_NAME=SYRA LMS
BREVO_SANDBOX=false
OPENAI_API_KEY=
FRONTEND_BASE_URL=http://localhost
BACKEND_BASE_URL=http://localhost/api
CORS_ORIGINS=http://localhost
AUTO_APPLY_MIGRATIONS=false
# WARNING: Only set to true for local development/testing. Never enable in production.
PRECHECK_ALLOW_TEST_BYPASS=false
WEB_REPORT_SCHEDULER_ENABLED=false
IDENTITY_RETENTION_DAYS=7
PROCTORING_VIDEO_RETENTION_DAYS=90
PROCTORING_EVIDENCE_RETENTION_DAYS=90
MAX_VIDEO_UPLOAD_MB=512
MEDIA_STORAGE_PROVIDER=local
PROCTORING_VIDEO_STORAGE_PROVIDER=cloudflare
PROCTORING_INFERENCE_MODE=celery
PROCTORING_INFERENCE_QUEUE=proctoring-inference
PROCTORING_INFERENCE_OPEN_TIMEOUT_SECONDS=180
PROCTORING_INFERENCE_TASK_TIMEOUT_SECONDS=30
# Optional remote fallback if you switch PROCTORING_INFERENCE_MODE=remote
AI_INFERENCE_URL=http://ai-inference:8081
PROCTORING_BATCH_ANALYSIS_ENABLED=true
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CLOUDFLARE_MEDIA_API_BASE_URL=
CLOUDFLARE_MEDIA_REQUIRE_SIGNED_URLS=true
CLOUDFLARE_MEDIA_WATERMARK_UID=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=syra-media
SUPABASE_SIGNED_URL_EXPIRES_SECONDS=3600
LOG_LEVEL=INFO
# Number of Gunicorn workers. Live monitoring state is stored in Redis (live_bus),
# so multiple workers are safe. docker-compose.yml defaults to 4; override here if needed.
# WORKERS=4
