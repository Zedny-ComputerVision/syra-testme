# ──────────────────────────────────────────────
# SYRA LMS Backend — Environment Configuration
# Copy to backend/.env and fill in your values.
# ──────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/syra_lms
# DB_POOL_SIZE=3
# DB_MAX_OVERFLOW=0
# DB_POOL_TIMEOUT_SECONDS=15
# DB_POOL_RECYCLE_SECONDS=1800

# ── Authentication ────────────────────────────
# REQUIRED — at least 32 random characters.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-random-32-character-string
JWT_ALGORITHM=HS256

# ── Email (Brevo) ────────────────────────────
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=SYRA LMS

# ── AI Features (optional) ───────────────────
OPENAI_API_KEY=

# ── URLs ──────────────────────────────────────
FRONTEND_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Logging ──────────────────────────────────
LOG_LEVEL=INFO

# ── Data Retention ───────────────────────────
IDENTITY_RETENTION_DAYS=7
PROCTORING_VIDEO_RETENTION_DAYS=90
PROCTORING_EVIDENCE_RETENTION_DAYS=90

# ── Upload Limits ────────────────────────────
MAX_VIDEO_UPLOAD_MB=512

# ── Media Storage ────────────────────────────
MEDIA_STORAGE_PROVIDER=local
PROCTORING_VIDEO_STORAGE_PROVIDER=local

# ── Cloudflare Stream (optional) ─────────────
CLOUDFLARE_MEDIA_API_BASE_URL=
CLOUDFLARE_MEDIA_REQUIRE_SIGNED_URLS=false
CLOUDFLARE_MEDIA_WATERMARK_UID=

# ── Supabase Storage (optional) ──────────────
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=syra-media
SUPABASE_SIGNED_URL_EXPIRES_SECONDS=3600
