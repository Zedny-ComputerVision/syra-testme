# ──────────────────────────────────────────────
# SYRA LMS — Environment Configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ──────────────────────────────────────────────

# ── Database ──────────────────────────────────
# PostgreSQL connection string (Supabase, Neon, local, etc.)
# Accepted prefixes: postgres://, postgresql://, postgresql+psycopg://
# If using the optional docker-compose db service:
#   DATABASE_URL=postgresql+psycopg://syra:${POSTGRES_PASSWORD}@db:5432/syra_lms
DATABASE_URL=postgresql+psycopg://postgres.your-project-ref:your-password@aws-0-your-region.pooler.supabase.com:5432/postgres

# Uncomment if using the docker-compose db service:
# POSTGRES_PASSWORD=change-me-strong-password

# Pool tuning (defaults are conservative for Supabase free tier)
# DB_POOL_SIZE=3
# DB_MAX_OVERFLOW=0
# DB_POOL_TIMEOUT_SECONDS=15
# DB_POOL_RECYCLE_SECONDS=1800

# ── Authentication ────────────────────────────
# REQUIRED — at least 32 random characters. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-random-32-character-string
JWT_ALGORITHM=HS256

# ── Email (Brevo / Sendinblue) ────────────────
# Leave blank to disable outbound email (password reset, welcome, etc.)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=SYRA LMS

# ── AI Features (optional) ───────────────────
# Used for AI-generated exam questions. Leave blank to disable.
OPENAI_API_KEY=

# ── URLs ──────────────────────────────────────
# Local dev URLs (used by backend for email links, CORS, etc.)
FRONTEND_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:8000

# Production URLs — used by docker-compose overrides
# IMPORTANT: Set these to your actual domain before deploying!
PUBLIC_FRONTEND_BASE_URL=https://your-frontend-domain.com
PUBLIC_BACKEND_BASE_URL=https://your-frontend-domain.com/api

# Comma-separated origins allowed by CORS.
# Must match your production frontend URL exactly (no trailing slash).
CORS_ORIGINS=https://your-frontend-domain.com

# ── Frontend Build ────────────────────────────
# Baked into the JS bundle at build time.
# For Docker: /api/  (nginx proxies to backend)
# For local dev: http://127.0.0.1:8000/api  (direct)
VITE_API_BASE_URL=/api/

# ── Docker / Ports ────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=80
MAX_VIDEO_UPLOAD_MB=512
NGINX_CLIENT_MAX_BODY_SIZE=512m

# Number of gunicorn worker processes (rule of thumb: 2 × CPU cores + 1)
WORKERS=2

# ── Database Migrations ──────────────────────
# Set to true to auto-run Alembic migrations on startup (recommended for Docker).
# docker-compose.yml defaults this to true.
AUTO_APPLY_MIGRATIONS=false

# ── Logging ──────────────────────────────────
LOG_LEVEL=INFO

# ── Data Retention ───────────────────────────
# Files older than these thresholds are deleted on startup and every 24h.
IDENTITY_RETENTION_DAYS=7
PROCTORING_VIDEO_RETENTION_DAYS=90
PROCTORING_EVIDENCE_RETENTION_DAYS=90

# ── Media Storage ────────────────────────────
# Where evidence screenshots and reports are stored: "local" or "supabase"
MEDIA_STORAGE_PROVIDER=local

# Where proctoring videos are stored: "local", "cloudflare", or "supabase"
# Proctoring review is configured for Cloudflare streaming by default.
PROCTORING_VIDEO_STORAGE_PROVIDER=cloudflare

# ── Cloudflare Stream (optional) ─────────────
# Only needed if PROCTORING_VIDEO_STORAGE_PROVIDER=cloudflare
CLOUDFLARE_MEDIA_API_BASE_URL=
CLOUDFLARE_MEDIA_REQUIRE_SIGNED_URLS=true
CLOUDFLARE_MEDIA_WATERMARK_UID=

# ── Supabase Storage (optional) ──────────────
# Only needed if MEDIA_STORAGE_PROVIDER=supabase or PROCTORING_VIDEO_STORAGE_PROVIDER=supabase
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=syra-media
SUPABASE_SIGNED_URL_EXPIRES_SECONDS=3600
